<UserControl x:Class="FileCounterPro_Windows.Views.ActivityMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SciFiBgDeep}" FontFamily="Consolas">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📊" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="ACTIVITY MONITOR" FontSize="22" FontWeight="Black" Foreground="{StaticResource SciFiNeonCyan}">
                    <TextBlock.Effect><DropShadowEffect Color="#00E6FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/></TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Real-time CPU · GPU · RAM · Network monitoring" FontSize="11" Foreground="{StaticResource SciFiTextDim}"/>
            </StackPanel>
            <Border Background="#1100FF80" BorderBrush="{StaticResource SciFiNeonGreen}" BorderThickness="1" CornerRadius="8" Padding="8,4" Margin="20,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource SciFiNeonGreen}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LIVE" FontSize="10" FontWeight="Black" Foreground="{StaticResource SciFiNeonGreen}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Stats Row -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
            <!-- CPU -->
            <Border Margin="0,0,8,0" Background="{StaticResource SciFiBgPanel}" BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="⚙" FontSize="13" Foreground="{StaticResource SciFiNeonCyan}" Margin="0,0,6,0"/>
                        <TextBlock Text="CPU USAGE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtCpuPct" Text="0" FontSize="36" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text="%" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SciFiNeonCyan}" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                    </StackPanel>
                    <ProgressBar x:Name="CpuBar" Height="6" Maximum="100" Value="0" Background="#15FFFFFF" Foreground="{StaticResource SciFiNeonCyan}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- GPU -->
            <Border Margin="4,0,4,0" Background="{StaticResource SciFiBgPanel}" BorderBrush="{StaticResource SciFiNeonMagenta}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🖥" FontSize="13" Foreground="{StaticResource SciFiNeonMagenta}" Margin="0,0,6,0"/>
                        <TextBlock Text="GPU USAGE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtGpuPct" Text="0" FontSize="36" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text="%" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SciFiNeonMagenta}" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                    </StackPanel>
                    <ProgressBar x:Name="GpuBar" Height="6" Maximum="100" Value="0" Background="#15FFFFFF" Foreground="{StaticResource SciFiNeonMagenta}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- RAM -->
            <Border Margin="4,0,4,0" Background="{StaticResource SciFiBgPanel}" BorderBrush="#FFFF9900" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="💾" FontSize="13" Foreground="#FFFF9900" Margin="0,0,6,0"/>
                        <TextBlock Text="RAM USED" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtRamUsed" Text="0.0" FontSize="36" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text=" GB" FontSize="14" FontWeight="Bold" Foreground="#FFFF9900" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <ProgressBar x:Name="RamBar" Height="6" Maximum="100" Value="0" Background="#15FFFFFF" Foreground="#FFFF9900" Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtRamTotal" Text="of 0 GB" FontSize="9" Foreground="{StaticResource SciFiTextDim}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Network -->
            <Border Margin="4,0,4,0" Background="{StaticResource SciFiBgPanel}" BorderBrush="{StaticResource SciFiNeonGreen}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🌐" FontSize="13" Foreground="{StaticResource SciFiNeonGreen}" Margin="0,0,6,0"/>
                        <TextBlock Text="NETWORK" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="↑ " FontSize="12" Foreground="{StaticResource SciFiNeonGreen}"/>
                        <TextBlock x:Name="TxtNetUp" Text="0 KB/s" FontSize="16" FontWeight="Black" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓ " FontSize="12" Foreground="{StaticResource SciFiNeonCyan}"/>
                        <TextBlock x:Name="TxtNetDown" Text="0 KB/s" FontSize="16" FontWeight="Black" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Power -->
            <Border Margin="8,0,0,0" Background="{StaticResource SciFiBgPanel}" BorderBrush="#FFFFD700" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="⚡" FontSize="13" Foreground="#FFFFD700" Margin="0,0,6,0"/>
                        <TextBlock Text="POWER USAGE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtPowerWatts" Text="0" FontSize="30" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text=" W" FontSize="14" FontWeight="Bold" Foreground="#FFFFD700" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtPowerStatus" Text="Calculating..." FontSize="10" Foreground="{StaticResource SciFiTextDim}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Process List -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="TOP PROCESSES" FontSize="13" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="  sorted by CPU usage" FontSize="10" Foreground="{StaticResource SciFiTextDim}" VerticalAlignment="Center"/>
            </StackPanel>

            <ListView x:Name="LstProcesses" Grid.Row="1"
                      Background="{StaticResource SciFiBgPanel}"
                      BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1"
                      Foreground="White" FontFamily="Consolas" FontSize="12">
                <ListView.Resources>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#15FFFFFF"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1500E6FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="PROCESS" Width="220" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="CPU %" Width="80" DisplayMemberBinding="{Binding CpuPercent}"/>
                        <GridViewColumn Header="RAM (MB)" Width="100" DisplayMemberBinding="{Binding MemoryMB}"/>
                        <GridViewColumn Header="PID" Width="70" DisplayMemberBinding="{Binding PID}"/>
                        <GridViewColumn Header="ACTION" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⛔ KILL" Tag="{Binding}" Style="{StaticResource DangerButtonStyle}"
                                            Padding="6,3" FontSize="10" Click="KillProcess_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
