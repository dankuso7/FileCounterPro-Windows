<UserControl x:Class="FileCounterPro_Windows.Views.DuplicateFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SciFiBgDeep}" FontFamily="Consolas">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="👯" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="DUPLICATE FILE FINDER" FontSize="22" FontWeight="Black" Foreground="{StaticResource SciFiNeonCyan}">
                    <TextBlock.Effect><DropShadowEffect Color="#00E6FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/></TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Find and remove duplicate files via MD5 hash comparison" FontSize="11" Foreground="{StaticResource SciFiTextDim}"/>
            </StackPanel>
        </StackPanel>

        <!-- Folder Picker -->
        <Border Grid.Row="1" Background="{StaticResource SciFiBgPanel}" BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtFolder" Background="{StaticResource SciFiBgDeep}" Foreground="{StaticResource SciFiNeonCyan}"
                         BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1" Padding="8,6"
                         Text="Select a folder to scan…" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="📁 BROWSE" Style="{StaticResource NeonButtonStyle}" Padding="12,7" Margin="8,0" Click="BtnBrowse_Click"/>
                <Button Grid.Column="2" x:Name="BtnScan" Content="🔍 SCAN" Style="{StaticResource NeonButtonStyle}" Padding="12,7" Click="BtnScan_Click"/>
            </Grid>
        </Border>

        <!-- Progress -->
        <ProgressBar Grid.Row="2" x:Name="ScanProgress" Height="6" Background="#15FFFFFF" Foreground="{StaticResource SciFiNeonCyan}"
                     Margin="0,0,0,10" Visibility="Collapsed" IsIndeterminate="False" CornerRadius="3"/>

        <!-- Stats Bar -->
        <Border Grid.Row="3" x:Name="StatsBar" Background="{StaticResource SciFiBgPanel}" BorderBrush="{StaticResource SciFiNeonMagenta}"
                BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="TxtStats" Text="" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SciFiNeonMagenta}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnKeepNewest" Content="🗑 Delete — Keep Newest" Style="{StaticResource DangerButtonStyle}" Padding="10,6" Margin="0,0,8,0" Click="BtnKeepNewest_Click"/>
                    <Button x:Name="BtnKeepOldest" Content="🗑 Delete — Keep Oldest" Style="{StaticResource DangerButtonStyle}" Padding="10,6" Click="BtnKeepOldest_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results -->
        <ListView Grid.Row="4" x:Name="LstDupes"
                  Background="{StaticResource SciFiBgPanel}"
                  BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1"
                  Foreground="White" FontFamily="Consolas">
            <ListView.Resources>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#15FFFFFF"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1500E6FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="FILE NAME" Width="200" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="SIZE" Width="90"  DisplayMemberBinding="{Binding SizeText}"/>
                    <GridViewColumn Header="COPIES" Width="70" DisplayMemberBinding="{Binding Count}"/>
                    <GridViewColumn Header="WASTED" Width="90" DisplayMemberBinding="{Binding WastedText}"/>
                    <GridViewColumn Header="LOCATIONS" Width="320" DisplayMemberBinding="{Binding PathsSummary}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status -->
        <Border Grid.Row="5" x:Name="StatusPanel" Background="{StaticResource SciFiBgPanel}" BorderBrush="#33FFFFFF"
                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0" Visibility="Collapsed">
            <TextBlock x:Name="TxtStatus" Text="" FontSize="11" Foreground="{StaticResource SciFiNeonGreen}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
