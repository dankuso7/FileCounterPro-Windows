<UserControl x:Class="FileCounterPro_Windows.Views.SmartUninstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SciFiBgDeep}" FontFamily="Consolas">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🗑️" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="SMART UNINSTALLER" FontSize="22" FontWeight="Black" Foreground="{StaticResource SciFiNeonCyan}">
                    <TextBlock.Effect><DropShadowEffect Color="#00E6FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/></TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Remove apps cleanly including leftover registry and data files" FontSize="11" Foreground="{StaticResource SciFiTextDim}"/>
            </StackPanel>
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnLoad" Content="📋 LOAD INSTALLED APPS" Style="{StaticResource NeonButtonStyle}" Padding="14,8" Click="BtnLoad_Click"/>
            <TextBox Grid.Column="1" x:Name="TxtSearch" Background="{StaticResource SciFiBgDeep}" Foreground="{StaticResource SciFiNeonCyan}"
                     BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1" Padding="10,6" Margin="10,0"
                     Text="" VerticalAlignment="Center" FontFamily="Consolas"
                     TextChanged="TxtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <Label Content="🔍 Search apps…" Foreground="#555" FontFamily="Consolas" FontSize="12"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource CueBannerBrush}"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Background" Value="{StaticResource CueBannerBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Grid.Column="2" x:Name="BtnFindLeftovers" Content="🔍 FIND LEFTOVERS" Style="{StaticResource NeonButtonStyle}" Padding="12,8" Margin="0,0,8,0" Click="BtnFindLeftovers_Click"/>
            <Button Grid.Column="3" x:Name="BtnUninstall" Content="🗑 UNINSTALL SELECTED" Style="{StaticResource DangerButtonStyle}" Padding="14,8" Click="BtnUninstall_Click" IsEnabled="False"/>
        </Grid>

        <!-- Progress -->
        <ProgressBar Grid.Row="2" x:Name="Progress" Height="6" Background="#15FFFFFF" Foreground="{StaticResource SciFiNeonCyan}"
                     Margin="0,0,0,12" Visibility="Collapsed" IsIndeterminate="True" CornerRadius="3"/>

        <!-- App List -->
        <ListView Grid.Row="3" x:Name="LstApps"
                  Background="{StaticResource SciFiBgPanel}"
                  BorderBrush="{StaticResource SciFiNeonCyan}" BorderThickness="1"
                  Foreground="White" FontFamily="Consolas"
                  SelectionChanged="LstApps_SelectionChanged"
                  SelectionMode="Extended">
            <ListView.Resources>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#15FFFFFF"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1500E6FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2200E6FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="APP NAME" Width="220" DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="PUBLISHER" Width="160" DisplayMemberBinding="{Binding Publisher}"/>
                    <GridViewColumn Header="VERSION" Width="100" DisplayMemberBinding="{Binding Version}"/>
                    <GridViewColumn Header="SIZE (MB)" Width="90" DisplayMemberBinding="{Binding SizeMB}"/>
                    <GridViewColumn Header="INSTALL DATE" Width="110" DisplayMemberBinding="{Binding InstallDate}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Selected info -->
        <Border Grid.Row="4" Background="{StaticResource SciFiBgPanel}" BorderBrush="#33FFFFFF" BorderThickness="1"
                CornerRadius="8" Padding="12" Margin="0,10,0,0">
            <TextBlock x:Name="TxtSelected" Text="Select apps to uninstall (use Ctrl+Click for multiple)" FontSize="11" Foreground="{StaticResource SciFiTextDim}"/>
        </Border>

        <!-- Status -->
        <Border Grid.Row="5" x:Name="StatusPanel" Background="{StaticResource SciFiBgPanel}" BorderBrush="#33FFFFFF"
                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,6,0,0" Visibility="Collapsed">
            <TextBlock x:Name="TxtStatus" Text="" FontSize="11" Foreground="{StaticResource SciFiNeonGreen}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
